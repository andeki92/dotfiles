# Brewfile for dotfiles setup
# Based on the Brewfile Guidelines from our dotfiles philosophy

# Development Tools
brew "coreutils"                # GNU core utilities
brew "git" if OS.mac?           # Version control
brew "git-lfs"                  # Git extension for versioning large files
brew "mise"                     # Tool version manager (replacing asdf, nvm, etc)
brew "squid" if OS.mac?         # Egress allow-list proxy for cbox sandbox
brew "stow"                     # Symlink farm manager for dotfiles
brew "tmux"                     # Terminal multiplexer (used by cbox for session lifecycle)
brew "tree"                     # Display directory structure

# Shells and CLI Utilities
brew "bash"              # Modern GNU bash (macOS ships an ancient 3.2)
brew "curl"              # URL transfer tool
brew "eza" if OS.mac?    # Modern ls replacement
brew "mas" if OS.mac?    # Mac App Store CLI
brew "wget"              # Internet file retriever
brew "zsh"               # Improved shell
brew "zsh-completions"   # Additional completions for zsh

# Applications
cask "ghostty"            # Terminal emulator
cask "karabiner-elements" # Keyboard customizer
cask "macfuse"            # EXT support
cask "obsidian"           # Markdown note-taking app
cask "orbstack"           # Alternative to Docker desktop

# Development Tools
cask "intellij-idea"            # IDE for JVM languages
cask "zed"		                # IDE
cask "git-credential-manager"

# Fonts
cask "font-jetbrains-mono-nerd-font"   # Developer font with programming ligatures and icons

# Mac App Store applications
mas "Amphetamine", id: 937984704
mas "Bitwarden", id: 1352778147
mas "Gemini 2", id: 1090488118
mas "Steam Link", id: 1246969117
mas "The Unarchiver", id: 425424353
mas "Xcode", id: 497799835
