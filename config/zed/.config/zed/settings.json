// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
    "anthropic_retention": false,
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
  },
  "cli_default_open_behavior": "existing_window",
  "ui_font_size": 16,
  "buffer_font_size": 15,

  // Catppuccin theming — kept consistent with ghostty / starship / nvim.
  // The extensions are auto-installed on launch (needs network the first time);
  // system appearance switches Latte (light) <-> Macchiato (dark), mirroring
  // ghostty's `light:catppuccin-latte,dark:catppuccin-macchiato`.
  "auto_install_extensions": {
    "catppuccin": true,
    "catppuccin-icons": true,
  },
  "theme": {
    "mode": "dark",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Macchiato",
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Macchiato",
  },
}
