# cbox container image — sandbox for running Claude Code (and other coding
# agents) under --dangerously-skip-permissions, with an iptables egress
# allow-list installed at container start by entrypoint.sh -> init-firewall.sh.
# All credentials (ssh-agent, gpg-agent socket; ~/.gitconfig and ~/.claude r/o)
# are mounted at runtime by the host wrapper (`cbox`); nothing sensitive lives
# in this image.
ARG BASE=debian:trixie-slim
FROM ${BASE}

ARG UID=1000
ARG GID=1000

ENV DEBIAN_FRONTEND=noninteractive \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    NODE_VERSION=22 \
    MISE_DATA_DIR=/home/agent/.local/share/mise \
    MISE_CACHE_DIR=/home/agent/.cache/mise

RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates curl wget gnupg sudo \
        git git-lfs \
        ripgrep fd-find jq bat less \
        iptables ipset dnsutils iputils-ping \
        openssh-client \
        build-essential pkg-config \
        python3 python3-venv \
    && rm -rf /var/lib/apt/lists/*

# Symlink debian's renamed tools to expected names.
RUN ln -sf /usr/bin/fdfind /usr/local/bin/fd \
 && ln -sf /usr/bin/batcat /usr/local/bin/bat

# Node.js 22 from NodeSource.
RUN curl -fsSL https://deb.nodesource.com/setup_${NODE_VERSION}.x | bash - \
 && apt-get install -y nodejs \
 && rm -rf /var/lib/apt/lists/*

# Claude Code (latest at build time).
RUN npm install -g @anthropic-ai/claude-code

# GitHub + GitLab CLIs.
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        -o /usr/share/keyrings/githubcli-archive-keyring.gpg \
 && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        > /etc/apt/sources.list.d/github-cli.list \
 && curl -fsSL https://gitlab.com/gitlab-org/cli/-/raw/main/scripts/install.sh | bash \
 && apt-get update && apt-get install -y --no-install-recommends gh \
 && rm -rf /var/lib/apt/lists/*

# fzf — small enough; no need to use the host's.
RUN apt-get update && apt-get install -y --no-install-recommends fzf \
 && rm -rf /var/lib/apt/lists/*

# mise — single binary install.
RUN curl -fsSL https://mise.run | sh \
 && mv /root/.local/bin/mise /usr/local/bin/mise

# Non-root user matched to the host UID/GID.
# If GID already exists in the base image (e.g. macOS users on GID 20 = dialout
# in debian), reuse it instead of failing with "GID already exists".
RUN if ! getent group ${GID} >/dev/null; then groupadd -g ${GID} agent; fi \
 && useradd -m -u ${UID} -g ${GID} -s /bin/bash agent \
 && mkdir -p /home/agent/.cache /home/agent/.config /home/agent/.local/share \
 && chown -R agent:agent /home/agent

# Passwordless sudo only for the firewall init script.
COPY init-firewall.sh /usr/local/bin/init-firewall.sh
RUN chmod +x /usr/local/bin/init-firewall.sh \
 && echo 'agent ALL=(root) NOPASSWD: /usr/local/bin/init-firewall.sh' \
        > /etc/sudoers.d/cbox-firewall \
 && chmod 0440 /etc/sudoers.d/cbox-firewall

COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

USER agent
WORKDIR /workspace

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["claude", "--dangerously-skip-permissions"]
